{"_id":"09pxmj5tzr7d","name":"Accurate Attack","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>When you make an accurate attack, you can take a penalty of up to –5 on the effect modifier of the attack and add the same number (up to +5) to your attack bonus.</p>","rang":1},"effects":[],"flags":{}}
{"_id":"qjrdkrbjtr","name":"Agile Feint","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You can use your Acrobatics bonus or movement speed rank in place of Deception to feint and trick in combat.</p>","rang":1},"effects":[],"flags":{}}
{"_id":"5vjnjelkpvc","name":"All-out Attack","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>When you make an all-out attack, you can take a penalty of up to –5 on your active defenses (Dodge and Parry) and add the same number (up to +5) to your attack bonus.</p>","rang":1},"effects":[],"flags":{}}
{"_id":"25iun08qjln","name":"Improved Initiative","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+4 bonus to initiative checks per rank.</p>","rang":1},"effects":[],"flags":{}}
{"_id":"1g4qmy0pmq7","name":"Iron Will","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+2 circumstance bonus on Will resistance checks.</p>","rang":1},"effects":[],"flags":{}}
