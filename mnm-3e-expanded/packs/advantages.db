{"name":"Attractive","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You are particularly attractive, giving you a +2 circumstance bonus on Deception and Persuasion checks to deceive, mislead, or influence others who are attracted to you. Rank 2 gives a +5 bonus.</p>","equipement":false,"rang":1,"edit":true,"listEffectsVariantes":{}},"effects":[],"_id":"6zdtpmg8zsg"}
