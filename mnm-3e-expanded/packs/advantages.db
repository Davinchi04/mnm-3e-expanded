{"_id":"tr2qs5xbcmo","name":"Eidetic Memory","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>Perfect recall. +5 circumstance bonus on memory checks. Can make Expertise checks as if trained.</p>","rang":1},"effects":[],"flags":{}}
{"_id":"0u73gsbvirt","name":"Animal Empathy","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You have a special connection with animals. You can use interaction skills on animals normally.</p>","rang":1},"effects":[],"flags":{}}
