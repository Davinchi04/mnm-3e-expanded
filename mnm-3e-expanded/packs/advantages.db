{"_id":"bmo3quiasua","name":"Eidetic Memory","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>Perfect recall. +5 circumstance bonus on memory checks. Can make Expertise checks as if trained.</p>","rang":1},"effects":[{"name":"Eidetic Memory Bonus","changes":[{"key":"system.competence.investigation.bonuses","mode":2,"value":"5","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}]}
