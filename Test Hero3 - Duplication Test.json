      "name": "Absorption",
      "type": "pouvoir",
      "img": "https://assets.forge-vtt.com/bazaar/systems/mutants-and-masterminds-3e/assets/assets/icons/pouvoir.svg",
      "system": {
        "type": "",
        "activate": true,
        "special": "standard",
        "action": "simple",
        "portee": "personal",
        "duree": "instantane",
        "notes": "<p>You take the energy from a particular type of attack, chosen when you take this power, and use it to enhance one of your traits. Typically this is either Strength or a Ranged Damage effect of the same energy type as the initial attack...</p>",
