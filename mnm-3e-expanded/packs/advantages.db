{"_id":"qwjbvsq8oy","name":"Accurate Attack","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>When you make an accurate attack, you can take a penalty of up to –5 on the effect modifier of the attack and add the same number (up to +5) to your attack bonus.</p>","rang":1},"effects":[],"flags":{}}
{"_id":"tgxbcj246x","name":"Agile Feint","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>You can use your Acrobatics bonus or movement speed rank in place of Deception to feint and trick in combat.</p>","rang":1},"effects":[{"name":"Agile Feint Bonus","changes":[{"key":"system.competence.acrobaties.bonuses","mode":2,"value":"2","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}],"flags":{}}
{"_id":"hlxvgqqyuiv","name":"All-out Attack","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>When you make an all-out attack, you can take a penalty of up to –5 on your active defenses (Dodge and Parry) and add the same number (up to +5) to your attack bonus.</p>","rang":1},"effects":[],"flags":{}}
{"_id":"9xxb67hq1ch","name":"Improved Initiative","type":"talent","img":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg","system":{"description":"<p>+4 bonus to initiative checks per rank.</p>","rang":1},"effects":[{"name":"Improved Initiative Bonus","changes":[{"key":"system.initiative.bonuses","mode":2,"value":"4","priority":20}],"disabled":false,"transfer":true,"icon":"systems/mutants-and-masterminds-3e/assets/icons/talent.svg"}],"flags":{}}
